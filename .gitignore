# ===============================
# 💡 General System/Editor Junk
# ===============================
.DS_Store               # MacOS finder metadata
Thumbs.db               # Windows thumbnail cache
*.log                   # Log files (tổng quát)
*.tmp                   # Temp files
*.swp                   # Vim swap files

# ===============================
# 💻 Node/NPM
# ===============================
node_modules/           # NPM dependencies (nặng, không cần commit)
npm-debug.log*          # NPM logs
yarn.lock               # Nếu bạn không dùng Yarn

# ===============================
# 🧠 Composer / PHP deps (nếu dùng)
# ===============================
vendor/                 # Composer dependencies
composer.lock

# ===============================
# 🔒 Sensitive files
# ===============================
.env                    # Môi trường (thường chứa DB password, secret key)

# ===============================
# 📦 Build / Output
# ===============================
*.zip                   # Các bản build zip của theme/plugin
*.tar.gz
*.sql                   # File dump database (.sql)

# ===============================
# 🧹 WordPress core (nếu không quản lý toàn site)
# ===============================
wp-admin/
wp-includes/
license.txt
readme.html

# ===============================
# 📁 WordPress Uploads/Cache
# ===============================
wp-content/uploads/                 # Uploads: hình ảnh, video — không cần commit
wp-content/cache/                   # Cache tạo ra bởi plugin (Autoptimize, WP Rocket)
wp-content/upgrade/                 # WP auto-upgrade files
wp-content/upgrade-temp-backup/    # Backup tạm sau khi update core/plugin/theme
wp-content/backups/                # Nếu có plugin backup tạo folder này

# ===============================
# 🔌 WordPress Plugins (KHÔNG deploy plugin bằng Git)
# ===============================
# Bỏ qua toàn bộ thư mục plugin — plugin sẽ được cài qua WP Admin hoặc deploy bằng cách khác
wp-content/plugins/
wp-content/plugins/*

# ===============================
# 🧾 Logs & Tệp tạm từ WordPress
# ===============================
wp-content/debug.log                # File lỗi khi WP_DEBUG=true

# ===============================
# 🔐 Plugin bảo mật / backup tự tạo
# ===============================
wp-content/siteguard/               # Ảnh CAPTCHA, log IP từ plugin SiteGuard
wp-content/wpvivid_uploads/         # Backup tạm thời của plugin WPvivid

# ===============================
# 🈳 Plugin tự sinh file dịch (WPForms, ContactForm 7...)
# ===============================
wp-content/languages/plugins/       # File dịch tự động — không cần commit nếu không chỉnh thủ công

# 🔤 Nếu bạn KHÔNG chỉnh sửa file dịch thủ công:
*.po
*.mo
*.pot

# ===============================
# 📁 IDEs / Tools
# ===============================
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ==========================================
# 🚫 LOẠI TRỪ FILE SAO LƯU DATABASE / TOKEN
# ==========================================
*.sql
clean-repo/
clean-token.txt
db-dumps/         # Loại trừ toàn bộ thư mục chứa export database
